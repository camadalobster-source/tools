# ── 必填 ──

# Claude API Key（AI 截圖分析用）
ANTHROPIC_API_KEY=sk-ant-...

# ClickUp Personal API Token（建單用）
CLICKUP_API_TOKEN=pk_...

# ClickUp Workspace ID（在 URL 中找到：https://app.clickup.com/{workspace_id}/home）
CLICKUP_WORKSPACE_ID=

# ── 選填（覆蓋 config.yaml 預設值）──

# ClickUp 預設狀態（預設：NEEDS FIX）
# CLICKUP_DEFAULT_STATUS=NEEDS FIX

# AI Model（預設：claude-sonnet-4-6）
# AI_MODEL=claude-sonnet-4-6
